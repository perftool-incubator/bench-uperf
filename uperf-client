#!/bin/bash
exec >uperf-client-stderrout.txt
exec 2>&1

. /usr/bin/uperf-base || (echo "/usr/bin/uperf-base not found"; exit 1)

dump_runtime
validate_label
validate_sw_prereqs jq ss uperf getopt ip

# defaults
nthreads=1
protocol="tcp"
wsize=1024
rsize=1024
think=0.001 # time in seconds
duration=60
remotehost=""
control_port=""
data_port=""
test_type="stream"
uopts=""
cpu_pin=""
ipv="4"
raw_ts="-R"
flow_control_rx_=""
flow_control_tx_=""
lro=""
rxd=""
txd=""
adaptive_rx=""
adaptive_tx=""
rx_usecs=""
tx_usecs=""
queues="default"
irqbalance=""
main_thread=""
worker_thread=""
priority=""
irq_pin=""

longopts="ipv:,test-type:,protocol:,rsize:,wsize:,nthreads:,remotehost:,
duration:,cpu-pin:,think:,passthru:,history:,histogram:,bucket-length:,
max-bucket:,adaptive-tx:,adaptive-rx:,lro:,tx-usecs:,rx-usecs:,rxd:,txd:,
flow-control-rx:,flow-control-tx:,queues:,priority:,irqbalance:,main-thread:,
quiet:,irq-pin:,worker-thread:"
opts=$(getopt -q -o "" --longoptions "$longopts" -n "getopt.sh" -- "$@");
if [ $? -ne 0 ]; then
    exit_error "Unrecognized option specified"
fi
eval set -- "$opts";
while true; do
    case "$1" in
        --quiet)
            shift
            if [ "$1" == "yes" ]; then
                uopts="$uopts -q"
                echo "uopts=$uopts"
            fi
            shift
            ;;
        --ipv)
            shift
            ipv="$1"
            echo "ipv=$ipv"
            shift
            ;;
        --irq-pin)
            shift
            irq_pin=$1
            echo "irq_pin=${irq_pin}"
            shift
            ;;
        --cpu-pin)
            shift
            cpu_pin=$1
            echo "cpu_pin=${cpu_pin}"
            shift
            ;;
        --test-type)
            shift
            test_type=$1
            echo "test_type=$test_type"
            if [ ! -e /tmp/xml-files/$test_type.xml ]; then
                exit_error "could not find /tmp/xml-files/$test_type.xml"
            fi
            shift
            ;;
        --nthreads)
            shift
            nthreads=$1
            echo "nthreads=$nthreads"
            shift
            ;;
        --protocol)
            shift
            protocol=$1
            echo "protocol=$protocol"
            shift
            ;;
        --rsize)
            shift
            rsize=$1
            echo "rsize=$rsize"
            shift
            ;;
        --wsize)
            shift
            wsize=$1
            echo "wsize=$wsize"
            shift
            ;;
        --think)
            shift
            think=$1
            echo "think=$think"
            shift
            ;;
        --remotehost)
            shift
            remotehost=$1
            echo "remotehost=$remotehost"
            shift
            ;;
        --duration)
            shift
            duration=$1
            echo "duration=$duration"
            shift
            ;;
        --passthru)     # uperf options that user wants passthru
            shift
            pt_opts=$1
            echo "pt_opts=$pt_opts"
            shift
            ;;
        --worker-thread)
            shift
            worker_thread=$1
            echo "worker-thread=$worker_thread"
            worker_thread_cpu="-W $worker_thread"
            shift
            ;;
        --main-thread)
            shift
            main_thread=$1
            echo "main-thread=$main_thread"
            main_thread_cpu="-M $main_thread"
            shift
            ;;
        --histogram)
            shift
            if [ "$1" == "yes" ]; then
                # Disable Raw timestamp (-R)
                raw_ts=""
                uopts="$uopts -H histogram.txt"
                echo "uopts=$uopts"
            fi
            shift
            ;;
        --bucket-length)
            shift
            bucket_len=$1
            echo "bucket-length=$bucket_len"
            uopts="$uopts -b $bucket_len"
            shift
            ;;
        --max-bucket)
            shift
            max_bucket=$1
            echo "max-bucket=$max_bucket"
            uopts="$uopts -B $max_bucket"
            shift
            ;;
        --history)
            shift
            if [ "$1" == "yes" ]; then
               uopts="$uopts -X history.txt"
               echo "uopts=$uopts"
            fi
            shift
            ;;
        --adaptive-tx)
            shift
            adaptive_tx=$1
            echo "adaptive_tx=$adaptive_tx"
            shift
            ;;
        --adaptive-rx)
            shift
            adaptive_rx=$1
            echo "adaptive_rx=$adaptive_rx"
            shift
            ;;
        --flow-control-tx)
            shift
            flow_control_tx=$1
            echo "flow_control_tx=$flow_control_tx"
            shift
            ;;
        --flow-control-rx)
            shift
            flow_control_rx=$1
            echo "flow_control_rx=$flow_control_rx"
            shift
            ;;
        --lro)
            shift
            lro=$1
            echo "lro=$lro"
            shift
            ;;
        --queues)
            shift
            queues=$1
            echo "queues=$queues"
            shift
            ;;
        --irqbalance)
            shift
            irqbalance=$1
            echo "irqbalance=$irqbalance"
            shift
            ;;
        --tx-usecs)
            shift
            tx_usecs=$1
            echo "tx_usecs=$tx_usecs"
            shift
            ;;
        --rx-usecs)
            shift
            rx_usecs=$1
            echo "rx_usecs=$rx_usecs"
            shift
            ;;
        --txd)
            shift
            txd=$1
            echo "txd=$txd"
            shift
            ;;
        --rxd)
            shift
            rxd=$1
            echo "rxd=$rxd"
            shift
            ;;
        --priority)
            shift
	    if [ "$1" == "0" ]; then
                echo "priority=0 (SCHED_OTHER)"
	    else
                priority=$1
                echo "priority=$priority"
                prio="-F $priority"
	    fi
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
             exit_error "Invalid option: $1"
    esac
done

cpu_pin_param=""
if echo "${cpu_pin}" | grep -q "^cpu:"; then
    cpu_pin_param=$(echo "${cpu_pin}" | awk -F: '{ print $2 }')
    cpu_pin=$(echo "${cpu_pin}" | awk -F: '{ print $1 }')
fi
case "${cpu_pin}" in
    ""|"cpu"|"numa")
	;;
    *)
	exit_error "unsupported cpu-pin value '${cpu_pin}'"
	;;
esac

if [ ! -e /tmp/xml-files/$test_type.xml ]; then
    exit_error "/tmp/xml-files/$test_type.xml was not found"
fi

# Unless the user specifies a specific remotehost argument, this must
# be sourced from the endpoint (which gets it from the client)
if [ -z "$remotehost" ]; then
    echo "--remotehost was not set via cmdline args, checking any messages from the endpoint"
    echo "These files exist in ./msgs/rx:"
    /bin/ls -l msgs/rx
    file="msgs/rx/endpoint-start-end:1"
    if [ ! -e "${file}" ]; then
	echo -n "Did not fine ${file}"
	file="msgs/rx/server-start-end:1"
	echo ", trying ${file}"
    fi
    if [ ! -e "${file}" ]; then
	echo -n "Did not find ${file}"
	file="msgs/rx/client-start:1"
	echo ", trying ${file}"
    fi
    if [ -e "$file" ]; then
        echo "Found $file"
        ipaddr=`jq -r '.svc.ip' $file`
        if [ ! -z "$ipaddr" ]; then
            echo "Found server IP $ipaddr"
            remotehost=$ipaddr
        fi
        port=`jq -r '.svc.ports[0]' $file`
        if [ ! -z "$port" ]; then
            echo "Found server control port $port"
            control_port=$port
        fi
        port=`jq -r '.svc.ports[1]' $file`
        if [ ! -z "$port" ]; then
            echo "Found server data port $port"
            data_port=$port
        fi
    else
        echo "Did not find $file, so cannot get an IP from the server/endpoint"
    fi
fi

# Confirm we have a remotehost (server) and ports
if [ -z "$remotehost" ]; then
    exit_error "remotehost is not set"
fi
# TODO: validate $remotehost with regex

ifname=$(ip route get ${remotehost} | head -n 1 | awk -F" dev " '{ print $2 }' | awk -F" src " '{ print $1 }')
if [ ! -e /sys/class/net/${ifname} ]; then
    exit_error "invalid interface '${ifname}' found"
fi

ifname_numa_node=-1
ifname_numa_node_cpus=-1
if [ -e /sys/class/net/${ifname}/device/numa_node ]; then
    ifname_numa_node=$(cat /sys/class/net/${ifname}/device/numa_node)
    if [ $ifname_numa_node == "-1" ] && [ "${cpu_pin}" == "numa" ]; then
        exit_error "PCIe has no NUMA locality, but cpu-pin is numa"
    fi
    if [ $ifname_numa_node == "-1" ] && [ "${irq_pin}" == "numa" ]; then
        exit_error "PCIe has no NUMA locality, but irq-pin is numa"
    fi
    ifname_numa_node_cpus=$(cat /sys/devices/system/node/node${ifname_numa_node}/cpulist)
elif [ "${cpu_pin}" == "numa" ] || [ "${irq_pin}" == "numa" ]; then
    exit_error "cannot determine numa node for interface '${ifname}' and cpu/irq-pin is numa"
fi

# NIC Statistics - last step in the new.conf (before running tests)
echo "ethtool -S $ifname" >> new.conf

# These ports should come from the endpoint, but if for some
# reason they don't the default port numbers are calculated
# in this way:
if [ -z "$control_port" ]; then
    let "control_port = 2 * $id"
    let "control_port = $control_port + 30000"
    echo "control_port was not set, using default of $control_port"
fi
if [ -z "$data_port" ]; then
    let "data_port = $control_port + 1"
    echo "data_port was not set, using default of $data_port"
fi
if [[ "$test_type" = "crr" ]]; then
    # show more details of connect/disconnect
    uopts="-tTfa"
fi

/bin/cp /tmp/xml-files/$test_type.xml test.xml

echo "ifname=${ifname}"
echo "ifname_numa_node=${ifname_numa_node}"
echo "remotehost=$remotehost"
echo "control_port=$control_port"
echo "data_port=$data_port"
echo "duration=$duration"
echo "wsize=$wsize"
echo "rsize=$rsize"
echo "think=$think"
echo "nthreads=$nthreads"
echo "protocol=$protocol"

cpu_pin_cmd=""
case "${cpu_pin}" in
    "numa")
	cpu_pin_cmd="taskset --cpu-list ${ifname_numa_node_cpus}"
        echo "CPU Pinning: NUMA [ $ifname_numa_node_cpus ]"
	;;
    "cpu")
	cpu_pin_cmd="taskset --cpu-list ${cpu_pin_param}"
        echo "CPU Pinning: CPUs [ $cpu_pin_param ]"
	;;
esac

irq_pin_mode=$(echo "${irq_pin}" | awk -F: '{ print $1 }')
case "${irq_pin_mode}" in
    "none")
	unset irq_affinity
	;;
    "default")
	irq_affinity=${HK_CPUS}
	;;
    "numa")
	irq_affinity=${ifname_numa_node_cpus}
	;;
    "cpu")
	irq_affinity=$(echo "${irq_pin}" | awk -F: '{ print $2 }')
	;;
esac
echo "IRQ Affinity: [ $irq_affinity ] : $irq_pin_mode "

# Interface tuning
if [ -n "$adaptive_rx" ]; then
    _adaptive_rx="$(ethtool -c $ifname | grep -i adaptive | awk '{ print $3 '})"
    echo "ethtool -C $ifname adaptive-rx $_adaptive_rx" >> orig.conf
    echo "ethtool -C $ifname adaptive-rx $adaptive_rx" >> new.conf
fi
if [ -n "$adaptive_tx" ]; then
    _adaptive_tx="$(ethtool -c $ifname | grep -i adaptive | awk '{ print $5 '})"
    echo "ethtool -C $ifname adaptive-tx $_adaptive_tx" >> orig.conf
    echo "ethtool -C $ifname adaptive-tx $adaptive_tx" >> new.conf
fi
if [ -n "$rx_usecs" ]; then
    _tx_usecs="$(ethtool -c $ifname | grep -i tx-usecs: | awk '{  print $2 }')"
    echo "ethtool -C $ifname rx-usecs $_rx_usecs" >> orig.conf
    echo "ethtool -C $ifname rx-usecs $rx_usecs" >> new.conf
fi
if [ -n "$tx_usecs" ]; then
    _rx_usecs="$(ethtool -c $ifname | grep -i rx-usecs: | awk '{  print $2 }')"
    echo "ethtool -C $ifname tx-usecs $_tx_usecs" >> orig.conf
    echo "ethtool -C $ifname tx-usecs $tx_usecs" >> new.conf
fi
if [ -n "$rxd" ]; then
    _rxd="$(ethtool -g $ifname | awk '/Current hardware settings:/{found=1} found && ($1=="RX:") {print $2}')"
    echo "ethtool -G $ifname rx $_rxd" >> orig.conf
    echo "ethtool -G $ifname rx $rxd" >> new.conf
fi
if [ -n "$txd" ]; then
    _txd="$(ethtool -g $ifname | awk '/Current hardware settings:/{found=1} found && ($1=="TX:") {print $2}')"
    echo "ethtool -G $ifname tx $_txd" >> orig.conf
    echo "ethtool -G $ifname tx $txd" >> new.conf
fi
if [ -n "$lro" ]; then
    _lro="$(ethtool -k $ifname | grep -i large-receive-offload | awk '{ print $2 }')"
    echo "ethtool -K $ifname lro $_lro" >> orig.conf
    echo "ethtool -K $ifname lro $lro" >> new.conf
fi
if [ -n "$flow_control_rx" ]; then
    _flow_control_rx="$(ethtool -a $ifname | grep RX | awk '{ print $2 '})"
    echo "ethtool -A $ifname rx $_flow_control_rx" >> orig.conf
    echo "ethtool -A $ifname rx $flow_control_rx" >> new.conf
fi
if [ -n "$flow_control_tx" ]; then
    _flow_control_tx="$(ethtool -a $ifname | grep TX | awk '{ print $2 '})"
    echo "ethtool -A $ifname tx $_flow_control_tx" >> orig.conf
    echo "ethtool -A $ifname tx $flow_control_tx" >> new.conf
fi
if [ -n "$queues" ]; then
    if [ "$queues" != "default" ]; then
        _queues="$(ethtool -l $ifname | awk '/Current hardware settings:/{found=1} found && ($1=="Combined:") {print $2}')"
        echo "ethtool -L $ifname combined $_queues" >> orig.conf
        if [ "$queues" == "match" ];then
            echo "ethtool -L $ifname combined $nthreads" >> new.conf
        else
            ethtool -L $ifname combined $queues
            echo "ethtool -L $ifname combined $queues" >> new.conf
        fi
    fi
fi

set -x
# IRQ affinity
if [ -n "${irq_affinity}" ]; then
    tuna show_threads -c ${irq_affinity}
    tuna show_irqs -q *${ifname}*
    for i in $(grep $ifname /proc/interrupts | awk '{ print $1 }' | sed 's/://'); do
        _irq_affinity="$( cat /proc/irq/$i/smp_affinity_list )"
        grep . /proc/irq/$i/smp_affinity_list
        echo "echo $_irq_affinity > /proc/irq/$i/smp_affinity_list" >> orig.conf
    done
    tuna isolate --cpus ${irq_affinity}
    tuna move -q *${ifname}* -c ${irq_affinity}
    tuna show_threads -c ${irq_affinity}
    tuna show_irqs -q *${ifname}*
fi

# NIC stats - first place in the orig.conf (after running tests)
echo "ethtool -S $ifname" >> orig.conf

echo "grep ${ifname} /proc/interrupts" >> new.conf

# Apply new settings
source new.conf
set +x

cmd+="${cpu_pin_cmd} uperf
 $main_thread_cpu $worker_thread_cpu
 $prio $raw_ts -m test.xml -P $control_port $uopts"

# strip ',' from the passthru options 
passthru_opts=$(echo "$pt_opts" | sed 's/,/ /g')
options+=" $passthru_opts"
echo "passthu options: $options"
cmd+="$options"

echo "uperf help"
uperf help

echo "going to run: ${cmd}"
nthreads=$nthreads \
protocol=$protocol \
remotehost=$remotehost \
duration=$duration \
wsize=$wsize \
rsize=$rsize \
think=$think \
port=$data_port \
${cmd} > uperf-client-result.txt 2>&1
uperf_rc=$?
uperf_errors=$(grep -i error uperf-client-result.txt)
if [ ${uperf_rc} -gt 0 -o -z "${uperf_errors}" ]; then
    if [ $test_type == "crr" ]; then
        # Do not error on this, as it is sadly common for CRR, and the test will resume anyway
        exit 0
    fi
    exit_error "$uperf_errors"
fi

echo "grep ${ifname} /proc/interrupts" >> orig.conf

# Restore original/previous settings
source orig.conf
