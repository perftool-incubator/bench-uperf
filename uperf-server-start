#!/bin/bash
exec >uperf-server-stderrout.txt 
exec 2>&1

. /usr/bin/uperf-base || (echo "/usr/bin/uperf-base not found"; exit 1)

dump_runtime
validate_label
validate_sw_prereqs jq ss uperf getopt ip

# defaults
control_port=""
data_port=""
ifname=""
cpu_pin=""
irq_pin=""
ipv="4"

longopts="ipv:,ifname:,cpu-pin:,passthru:,adaptive-rx:,adaptive-tx:,
flow-control-tx:,flow-control-rx:,rxd:,txd:,lro:,queues:,queues:,tx-usecs:,
rx-usecs:,priority:,main-thread:,irqbalance:,irq-pin:"
opts=$(getopt -q -o "" --longoptions "$longopts" -n "getopt.sh" -- "$@");
if [ $? -ne 0 ]; then
    exit_error  "Unrecognized option specified"
fi
eval set -- "$opts";
while true; do
    case "$1" in
        --irq-pin)
            shift
            irq_pin=$1
            echo "irq_pin=${irq_pin}"
            shift
            ;;
        --cpu-pin)
            shift;
            cpu_pin=$1
            echo "cpu_pin=${cpu_pin}"
            shift;
            ;;
	--main-thread)
	    shift
	    main_thread=$1
	    echo "main-thread=$main_thread"
            main_thread_cpu="-M $main_thread"
	    shift
	    ;;
        --ipv)
            shift;
            ipv=$1
            echo "ipv=${ipv}"
            shift;
            ;;
        --ifname)
            shift;
            ifname="$1"
            echo "ifname=$ifname"
            shift
            ;;
        --test-type|--nthreads|--protocol|--rsize|--wsize|--remotehost|--duration|--think)
            shift;
            shift;
            ;;
        --passthru)     # uperf options that user wants passthru
            shift;
            pt_opts=$1
            echo "pt_opts=$pt_opts"
            shift
            ;;
        --adaptive-tx)
            shift
            adaptive_tx=$1
            echo "adaptive_tx=$adaptive_tx"
            shift
            ;;
        --adaptive-rx)
            shift
            adaptive_rx=$1
            echo "adaptive_rx=$adaptive_rx"
            shift
            ;;
        --flow-control-tx)
            shift
            flow_control_tx=$1
            echo "flow_control_tx=$flow_control_tx"
            shift
            ;;
        --flow-control-rx)
            shift
            flow_control_rx=$1
            echo "flow_control_rx=$flow_control_rx"
            shift
            ;;
        --lro)
            shift
            lro=$1
            echo "lro=$lro"
            shift
            ;;
        --queues)
            shift
            queues=$1
            echo "queues=$queues"
            shift
            ;;
        --irqbalance)
            shift
            irqbalance=$1
            echo "irqbalance=$irqbalance"
            shift
            ;;
        --tx-usecs)
            shift
            tx_usecs=$1
            echo "tx_usecs=$tx_usecs"
            shift
            ;;
        --rx-usecs)
            shift
            rx_usecs=$1
            echo "rx_usecs=$rx_usecs"
            shift
            ;;
        --txd)
            shift
            txd=$1
            echo "txd=$txd"
            shift
            ;;
        --rxd)
            shift
            rxd=$1
            echo "rxd=$rxd"
            shift
            ;;
        --priority)
            shift
	    if [ "$1" == "0" ]; then
		echo "Priority 0: SCHED_OTHER"
	    else
                priority=$1
                echo "priority=$priority"
                prio="-F $priority"
	    fi
            shift
            ;;
        --)
            shift;
            break
            ;;
        *)
            exit_error "Invalid option: $1"
    esac
done

cpu_pin_param=""
if echo "${cpu_pin}" | grep -q "^cpu:"; then
    cpu_pin_param=$(echo "${cpu_pin}" | awk -F: '{ print $2 }')
    cpu_pin=$(echo "${cpu_pin}" | awk -F: '{ print $1 }')
fi
case "${cpu_pin}" in
    ""|"cpu"|"numa")
	;;
    *)
	exit_error "unsupported cpu-pin value '${cpu_pin}'"
	;;
esac

irq_pin_mode=$(echo "${irq_pin}" | awk -F: '{ print $1 }')
case "${irq_pin_mode}" in
    "none")
       unset irq_affinity
       ;;
    "default")
       irq_affinity=$( taskset -cp 1 )
       ;;
    "numa")
       irq_affinity=${ifname_numa_node_cpus}
       ;;
    "cpu")
       irq_affinity=$(echo "${irq_pin}" | awk -F: '{ print $2 }')
       ;;
esac
echo "IRQ Affinity: $irqaffinity"

# NIC Statistics - last step in the new.conf (before running tests)
echo "ethtool -S $ifname" >> new.conf

# A benchmark server can provide both an IP and ports to the client.
# The server must package these in a JSON, which will be sent to
# the endpoint.  The endpoint may make adjustments to the IP and
# ports depending on the network and security model.

# There are always 2 ports for these uperf tests, and ports should always
# start at 30000 to avoid port number reassignment
let "control_port = 2 * $id"
let "control_port = $control_port + 30000"
let "data_port = $control_port + 1"

# If --remotehost is not used by the user, they can pass --ifname, a netdev name
# like "eth0", and the server (below) will try to resolve this to the actual IP address.
# This allows the user to not know the IP address in advance.
ip=""
ip -j a >ip.json
if [ ! -z "$ifname" ]; then
    if echo $ifname | grep -q '%id:'; then
        # We have the role ID variable embedded, so we need to extract the value
        before_var=`echo $ifname | sed -e 's/\(.*\)%id:.*%/\1/'`
        after_var=`echo $ifname | sed -e 's/.*%id:.*%\(.*\)/\1/'`
        var=`echo $ifname | sed -e 's/%id:\(.*\)%/\1/' | jq -r '."'$id'"'`
        ifname="${before_var}${var}${after_var}"
    fi
    if [ "${ifname}" == "default-route" ]; then
       echo "Looking for default route interface..."
       ip -j route > route.json
       ifname=$(jq --raw-output 'to_entries | .[] | if (.value.dst == "default") then .value.dev else null end' route.json | grep -v null)
       if [ -z "${ifname}" ]; then
           exit_error "could not find default route interface"
       else
           echo "Found default route on interface ${ifname}"
       fi
    else
       echo "--ifname=${ifname} was found"
    fi
    echo "Searching for IP for interface ${ifname}..."

    echo "--ifname=$ifname was found, searching for IP"
    # Find the element in the 'ip a' array that matches the ifname we are looking for
    ifname_idx=`jq 'to_entries | .[] | if (.value.ifname == "'$ifname'") then .key else null end' ip.json | grep -v null`
    if [ ! -z "$ifname_idx" ]; then
        if [ "$ipv" == "4" ]; then
            echo "$ifname matches index $ifname_idx, looking for ipv4 (inet) in addr_info:"
            jq '.['$ifname_idx'].addr_info' ip.json
            # Find the first ipv4 address
            addr_idx=`jq '.['$ifname_idx'].addr_info | to_entries | .[] | if (.value.family == "inet") then .key else null end' ip.json | grep -v null | head -1`
            if [ ! -z $addr_idx ]; then
                echo "Found inet in index $addr_idx:"
                jq -r '.['$ifname_idx'].addr_info['$addr_idx']' ip.json
                ip=`jq -r '.['$ifname_idx'].addr_info['$addr_idx'].local' ip.json`
            else
                addr_info=`jq '.['$ifname_idx'].addr_info' ip.json`
                exit_error "An IPV4 address could not be found for $ifname in addr_info: $addr_info"
            fi
        elif [ "$ipv" == "6" ]; then
            echo "$ifname matches index $ifname_idx, looking for ipv6 (inet6) in addr_info:"
            jq '.['$ifname_idx'].addr_info' ip.json
            # Find the first ipv4 address
            addr_idx=`jq '.['$ifname_idx'].addr_info | to_entries | .[] | if (.value.family == "inet6") then .key else null end' ip.json | grep -v null | head -1`
            if [ ! -z $addr_idx ]; then
                echo "Found inet in index $addr_idx:"
                jq -r '.['$ifname_idx'].addr_info['$addr_idx']' ip.json
                ip=`jq -r '.['$ifname_idx'].addr_info['$addr_idx'].local' ip.json`
            else
                addr_info=`jq '.['$ifname_idx'].addr_info' ip.json`
                exit_error "An IPV6 address could not be found for $ifname in addr_info: $addr_info"
            fi
        else
            exit_error "The value for --ipv, $ipv, is not supported.  Use 4 for ipv4 or 6 for ipv6"
        fi
    else
        interfaces=`jq -r '. | to_entries | .[] | .value.ifname' ip.json`
        exit_error "could not find netdev $ifname, interfaces are: $interfaces"
    fi
    if [ -z "$ip" ]; then
        exit_error "IP was not found from $ifname"
    else
        echo "IP was found: $ip"
    fi
else
    echo "Not going to look for an IP since --ifname was not used."
fi

# Queue ip/port info, to be sent to endpoint
echo '{"recipient":{"type":"all","id":"all"},"user-object":{"svc":{"ip":"'$ip'","ports":['$control_port,$data_port']}}}' >msgs/tx/svc

echo "Existing listening ports:"
ss -tlnp
echo

# Kill any existing process using this port
echo "Attempt to kill port $control_port via 'ss' if it exists:"
ss -tlnpK '( sport = '$control_port' )'
echo

pid=`ss -Otlnp '( sport = '$control_port' )' | awk '{print $6}' | grep -v Peer | awk -Fpid= '{print $2}' | awk -F, '{print $1}' | sort | uniq`
if [ ! -z "$pid" ]; then
    echo "Trying to force kill PID $pid with 'kill -9'"
    kill -9 $pid
fi

echo "Existing listening ports (after kill):"
ss -tlnp
echo
#TODO: exit with error if ports still used

ifname_numa_node=-1
ifname_numa_node_cpus=-1
if [ -e /sys/class/net/${ifname}/device/numa_node ]; then
    ifname_numa_node=$(cat /sys/class/net/${ifname}/device/numa_node)
    if [ $ifname_numa_node == "-1" ] && [ "${cpu_pin}" == "numa" ]; then
        exit_error "PCIe has no NUMA locality, but cpu-pin is numa"
    fi
    ifname_numa_node_cpus=$(cat /sys/devices/system/node/node${ifname_numa_node}/cpulist)
elif [ "${cpu_pin}" == "numa" ]; then
    exit_error "cannot determine numa node for interface '${ifname}' and cpu-pin is numa"
fi

echo "ifname=${ifname}"
echo "ifname_numa_node=${ifname_numa_node}"

cpu_pin_cmd=""
case "${cpu_pin}" in
    "numa")
	cpu_pin_cmd="taskset --cpu-list ${ifname_numa_node_cpus}"
	if [ "${irq_pin}" == "yes" ]; then
	    irq_affinity=${ifname_numa_node_cpus}
	fi
	;;
    "cpu")
	cpu_pin_cmd="taskset --cpu-list ${cpu_pin_param}"
	if [ "${irq_pin}" == "yes" ]; then
	    irq_affinity=${cpu_pin_param}
	fi
	;;
esac

# Interface tuning
if [ -n "$adaptive_rx" ]; then
    _adaptive_rx="$(ethtool -c $ifname | grep -i adaptive | awk '{ print $3 '})"
    echo "ethtool -C $ifname adaptive-rx $_adaptive_rx" >> orig.conf
    echo "ethtool -C $ifname adaptive-rx $adaptive_rx" >> new.conf
fi
if [ -n "$adaptive_tx" ]; then
    _adaptive_tx="$(ethtool -c $ifname | grep -i adaptive | awk '{ print $5 '})"
    echo "ethtool -C $ifname adaptive-tx $_adaptive_tx" >> orig.conf
    echo "ethtool -C $ifname adaptive-tx $adaptive_tx" >> new.conf
fi
if [ -n "$rx_usecs" ]; then
    _tx_usecs="$(ethtool -c $ifname | grep -i tx-usecs: | awk '{  print $2 }')"
    echo "ethtool -C $ifname rx-usecs $_rx_usecs" >> orig.conf
    echo "ethtool -C $ifname rx-usecs $rx_usecs" >> new.conf
fi
if [ -n "$tx_usecs" ]; then
    _rx_usecs="$(ethtool -c $ifname | grep -i rx-usecs: | awk '{  print $2 }')"
    echo "ethtool -C $ifname tx-usecs $_tx_usecs" >> orig.conf
    echo "ethtool -C $ifname tx-usecs $tx_usecs" >> new.conf
fi
if [ -n "$rxd" ]; then
    _rxd="$(ethtool -g $ifname | awk '/Current hardware settings:/{found=1} found && ($1=="RX:") {print $2}')"
    echo "ethtool -G $ifname rx $_rxd" >> orig.conf
    echo "ethtool -G $ifname rx $rxd" >> new.conf
fi
if [ -n "$txd" ]; then
    _txd="$(ethtool -g $ifname | awk '/Current hardware settings:/{found=1} found && ($1=="TX:") {print $2}')"
    echo "ethtool -G $ifname tx $_txd" >> orig.conf
    echo "ethtool -G $ifname tx $txd" >> new.conf
fi
if [ -n "$lro" ]; then
    _lro="$(ethtool -k $ifname | grep -i large-receive-offload | awk '{ print $2 }')"
    echo "ethtool -K $ifname lro $_lro" >> orig.conf
    echo "ethtool -K $ifname lro $lro" >> new.conf
fi
if [ -n "$flow_control_rx" ]; then
    _flow_control_rx="$(ethtool -a $ifname | grep RX | awk '{ print $2 '})"
    echo "ethtool -A $ifname rx $_flow_control_rx" >> orig.conf
    echo "ethtool -A $ifname rx $flow_control_rx" >> new.conf
fi
if [ -n "$flow_control_tx" ]; then
    _flow_control_tx="$(ethtool -a $ifname | grep TX | awk '{ print $2 '})"
    echo "ethtool -A $ifname tx $_flow_control_tx" >> orig.conf
    echo "ethtool -A $ifname tx $flow_control_tx" >> new.conf
fi
if [ -n "$queues" ]; then
    if [ "$queues" != "default" ]; then
        _queues="$(ethtool -l $ifname | awk '/Current hardware settings:/{found=1} found && ($1=="Combined:") {print $2}')"
        echo "ethtool -L $ifname combined $_queues" >> orig.conf
        if [ "$queues" == "match" ];then
            echo "ethtool -L $ifname combined $nthreads" >> new.conf
        else
            ethtool -L $ifname combined $queues
            echo "ethtool -L $ifname combined $queues" >> new.conf
        fi
    fi
fi

# IRQ affinity
if [ -n "${irq_affinity}" ]; then
    tuna show_threads -c ${irq_affinity}
    tuna show_irqs -q *${ifname}*
    for i in $(grep $ifname /proc/interrupts | awk '{ print $1 }' | sed 's/://'); do
        _irq_affinity="$( cat /proc/irq/$i/smp_affinity_list )"
        grep . /proc/irq/$i/smp_affinity_list
        echo "echo $_irq_affinity > /proc/irq/$i/smp_affinity_list" >> orig.conf
    done
    tuna isolate --cpus ${irq_affinity}
    tuna move -q *${ifname}* -c ${irq_affinity}
    tuna show_threads -c ${irq_affinity}
    tuna show_irqs -q *${ifname}*
fi

# NIC stats - first place in the orig.conf (after running tests)
echo "ethtool -S $ifname" >> orig.conf

# Apply new settings
source new.conf

cmd="${cpu_pin_cmd} uperf -s -P $control_port $prio $main_thread_cpu"

# strip ',' from the passthru options 
passthru_opts=$(echo "$pt_opts" | sed 's/,/ /g')
options+=" $passthru_opts"
echo "passthu options: $options"

cmd+="$options"

echo "going to run: $cmd"
export MALLOC_CHECK_=2
$cmd 2>&1 >uperf-server-start.txt &
pid=$!
echo $pid >uperf-server.pid
# Wait a little bit to see if the server errored out
sleep 10
if grep -q -i error uperf-server-start.txt; then
    exit_error "Server failed to start: `grep -i error uperf-server-start.txt`"
fi
echo ps:
ps aux | grep uperf
echo
echo ss -tlnp:
ss -tlnp
exit 0
