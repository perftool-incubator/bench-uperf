{
    "workshop": {
        "schema": {
            "version": "2020.03.02"
        }
    },
    "userenvs": [
	    {
	        "name": "default",
	        "requirements": [
                        "deps",
                        "uperf_fork"
	        ]
	    }
    ],
    "requirements": [
	    {
	        "name": "uperf_src",
	        "type": "source",
	        "source_info": {
		        "url": "https://github.com/uperf/uperf/archive/1.0.7.tar.gz",
		        "filename": "1.0.7.tar.gz",
		        "commands": { 
		            "unpack": "tar -xzf 1.0.7.tar.gz",
		            "get_dir": "tar -tzf 1.0.7.tar.gz | head -n 1",
		            "commands": [
			            "CFLAGS=\"-ggdb\" ./configure --disable-sctp",
			            "make",
			            "make install",
			            "ldconfig",
			            "/usr/local/bin/uperf -V"
		            ]
                }
	        }
	    },
	    {
	        "name": "uperf_fork",
	        "type": "manual",
	        "manual_info": {
		        "commands": [
				"git clone https://github.com/rafaelfolco/uperf.git /root/uperf",
				"cd /root/uperf && git checkout master",
				"cd /root/uperf && autoreconf --install && ./configure && make install",
				"cd /root/uperf && ldconfig && /usr/local/bin/uperf -V"
		        ]
	        }
            },
            {
                "name": "deps",
                "type": "distro",
                "distro_info": {
                    "packages": [
		        "lksctp-tools-devel"
		    ]
                }
            }
    ]
}
